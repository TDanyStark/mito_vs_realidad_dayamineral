---
import { URL_BASE } from "@/config";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <div
    id="quiz-wrapper"
    class="min-h-screen flex flex-col bg-cover bg-position-[center_top] transition-[background-image] duration-300 md:bg-center lg:bg-position-[center_center]"
    style={`background-image: url(${URL_BASE}/backgrounds/bg_01.webp);`}
  >
    <header class="w-7xl relative mx-auto max-w-full p-4 md:p-6">
      <div class="flex justify-between">
        <div>
          <a href={URL_BASE}>
            <img
              id="quiz-abbott-logo"
              class="w-32"
              src={`${URL_BASE}/logos/abbott_black.webp`}
              alt="Logo Abbott"
            />
          </a>
        </div>
        <div>
          <img
            id="quiz-dayamineral-logo"
            class="w-44"
            src={`${URL_BASE}/logos/logo_dayamineral_color.webp`}
            alt="Logo Dayamineral"
          />
        </div>
      </div>

      <div class="absolute top-16 -right-2 -rotate-90 transform lg:-right-8 xl:-right-12">
        <span id="quiz-header-code" class="text-sm text-black"></span>
      </div>
    </header>
    <main
      class="mx-auto flex w-full max-w-7xl flex-1 justify-end p-4"
    >
      <section
        id="quiz-card"
        class="w-full rounded-4xl p-5 text-black sm:p-7 md:max-w-xl lg:mr-[5vw] lg:w-[47%] lg:max-w-140 lg:p-0 "
        aria-live="polite"
      >
        <div class="sr-only">
          <img
            src={`${URL_BASE}/logos/logo_dayamineral_color.webp`}
            alt="Dayamineral"
            class="h-auto w-36 md:w-44"
          />
        </div>

        <p class="sr-only">
          <img
            src={`${URL_BASE}/iconos/rayo.webp`}
            alt=""
            class="h-5 w-5"
            aria-hidden="true"
          />
          Mito o realidad
        </p>

        <div class="mb-5 flex w-full lg:w-[90%] items-center gap-3 md:mb-6">
          <div
            class="h-2.5 flex-1 overflow-hidden rounded-full bg-white/60 shadow-inner"
            role="progressbar"
            aria-label="Progreso del quiz"
            aria-valuemin="1"
            aria-valuemax="6"
            aria-valuenow="1"
            id="quiz-progress"
          >
            <div
              id="quiz-progress-bar"
              class="h-full rounded-full bg-linear-to-r from-[#c62579] to-[#f4bd18] transition-[width] duration-300"
              style="width: 16.6667%;"
            ></div>
          </div>
          <button
            id="quiz-reset"
            type="button"
            class="shrink-0 rounded-full border border-current px-3 py-1 text-xs font-black uppercase tracking-wide transition hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
          >
            Reset
          </button>
        </div>

        <div
          id="quiz-question-copy"
          class="flex items-start gap-3 rounded-3xl bg-(--question-copy-bg) p-4 text-black md:gap-4 md:bg-transparent md:p-0"
        >
          <p
            id="quiz-counter"
            class="shrink-0 text-[clamp(1.7rem,2.5vw,2.75rem)] font-black leading-[1.04]"
          >
            1.
          </p>
          <h1
            id="quiz-question"
            class="min-h-36 text-balance text-[clamp(1.7rem,2.5vw,2.75rem)] font-normal leading-[1.04] md:min-h-48 [&_strong]:font-black"
          >
            Las personas que tienen una dieta saludable no necesitan un suplemento con vitaminas y minerales como <strong>Dayamineral</strong>
          </h1>
        </div>

        <div id="quiz-answers" class="mt-8 flex w-full max-w-107.5 flex-col gap-4 md:mt-10"></div>
      </section>

      <section
        id="quiz-finish"
        class="hidden w-full rounded-4xl bg-white/84 p-6 text-center text-black shadow-2xl backdrop-blur-sm md:max-w-xl md:p-8 lg:mr-[5vw] lg:w-[47%] lg:max-w-140"
        aria-live="polite"
      >
        <img
          src={`${URL_BASE}/logos/logo_dayamineral_color.webp`}
          alt="Dayamineral"
          class="mx-auto mb-6 h-auto w-48 md:w-60"
        />
        <img
          src={`${URL_BASE}/iconos/check.webp`}
          alt=""
          class="mx-auto mb-5 h-14 w-14"
          aria-hidden="true"
        />
        <h2 class="text-4xl font-black leading-none md:text-6xl">¡Terminaste!</h2>
        <p class="mx-auto mt-4 max-w-md text-lg font-bold md:text-xl">
          Ahora conoces más sobre los mitos y realidades de la suplementación con Dayamineral.
        </p>
        <button
          id="quiz-restart"
          type="button"
          class="mt-8 rounded-full bg-[#f4bd18] px-8 py-4 text-lg font-black uppercase text-white shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl focus-visible:outline-4 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          Reiniciar
        </button>
      </section>
    </main>

    <footer
      id="quiz-footer"
      class="mx-auto flex w-full max-w-7xl px-4 pb-4 text-[0.625rem] font-normal leading-snug text-black/80 transition-colors sm:text-xs lg:justify-end"
    >
      <div class="w-full lg:mr-[5vw] lg:w-[47%] lg:max-w-140">
        <div id="quiz-footer-references"></div>
      </div>
    </footer>

    <div
      id="quiz-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/55 p-4 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modal-title"
    >
      <article
        id="modal-card"
        class="max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-4xl bg-white p-6 text-white shadow-2xl md:p-8 flex flex-col items-center text-center"
      >
        <div class="mb-4 text-center">
          <img
            id="modal-icon"
            src={`${URL_BASE}/iconos/check.webp`}
            alt=""
            class="mx-auto mb-3 h-auto w-12"
            aria-hidden="true"
          />
          <h2 id="modal-title" class="text-3xl font-black leading-none md:text-5xl">
            ¡Correcto!
          </h2>
        </div>
        <p id="modal-message" class="text-lg leading-relaxed md:text-xl"></p>
        <button
          id="modal-next"
          type="button"
          class="mt-7 w-full rounded-full bg-[#f4bd18] px-8 py-4 text-lg font-black uppercase text-white shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl focus-visible:outline-4 focus-visible:outline-offset-2 focus-visible:outline-[#c62579] sm:w-auto"
        >
          SIGUIENTE
        </button>
      </article>
    </div>
  </div>
</Layout>

<style>
  :global(.quiz-answer) {
    background-color: #c62579;
    background-image: var(--answer-gradient);
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  :global(.quiz-answer:hover) {
    background-color: #f4bd18;
    background-image: none;
  }

</style>

<script>
  import confetti from "canvas-confetti";

  window.quizConfetti = confetti;
</script>

<script is:inline define:vars={{ URL_BASE }}>
  const questions = [
    {
      questionHtml:
        "Las personas que tienen una dieta saludable no necesitan un suplemento con vitaminas y minerales como <strong>Dayamineral</strong>",
      options: [
        { label: "MITO" },
        { label: "REALIDAD" },
      ],
      correct: "MITO",
      message:
        "La realidad es que la mayoría de las personas, incluso si tienen una dieta variada y saludable, no ingieren la cantidad diaria necesaria de nutrientes esenciales. En parte, esto se debe a que actualmente muchos de los alimentos que consumimos son menos ricos en nutrientes que hace décadas, de modo que es muy probable que la dieta no alcance a cubrir todas las necesidades que el cuerpo necesita.",
      referencesHtml:
        "<strong>Referencias:</strong> <strong>1.</strong> Mister S. Five Myths About Dietary Supplements-And the Truth You Should Know. Integr Med (Encinitas). 2025 Dec;24(6):14-15. <strong>2.</strong> Monografía Dayamineral Jarabe. Junio 2019. <strong>3.</strong> Monografía Dayamineral Tabletas Recubiertas. Marzo 2019.",
      textColor: "#111827",
      logoVariant: "dark",
    },
    {
      questionHtml: "Las carencias nutricionales no son realmente importantes",
      options: [
        { label: "MITO" },
        { label: "REALIDAD" },
      ],
      correct: "MITO",
      message:
        "Es todo lo contrario, ya que las vitaminas y minerales influyen directamente en la salud a largo plazo, por lo que es muy importante mantener unos niveles adecuados. Por ejemplo, los niveles óptimos de vitaminas, como la D, se asocian con una mejor función inmunitaria. Asimismo, las personas que consumen multivitamínicos presentan un menor deterioro cognitivo a medida que envejecen.",
      referencesHtml:
        "<strong>Referencia:</strong> Mister S. Five Myths About Dietary Supplements-And the Truth You Should Know. Integr Med (Encinitas). 2025 Dec;24(6):14-15.",
      textColor: "#ffffff",
      logoVariant: "light",
    },
    {
      questionHtml:
        "Un suplemento multivitamínico de calidad, como <strong>Dayamineral</strong>, ayuda a las personas a tener un buen desempeño físico y mental",
      options: [
        { label: "MITO" },
        { label: "REALIDAD" },
      ],
      correct: "REALIDAD",
      message:
        "Dado que Dayamineral ayuda a obtener las cantidades necesarias de nutrientes que no son cubiertas con la alimentación, las personas que lo consumen obtienen un aumento de la energía, así como una mejora del metabolismo, el sistema inmune y la función cognitiva.",
      referencesHtml:
        "<strong>Referencias:</strong> <strong>1.</strong> Office of Dietary Supplements. Multivitamin/mineral supplements: fact sheet for health professionals [Internet]. Bethesda (MD): National Institutes of Health. Disponible en: https://n9.cl/tjvn01 <strong>2.</strong> Garg V, Lin J, Gadzhieva-Moore A, et al. The role of multivitamin and mineral supplements in supporting health and well-being: a retrospective cross-sectional study in Taiwan. J Health Popul Nutr. 2025;44(1):423.",
      textColor: "#111827",
      logoVariant: "dark",
    },
    {
      questionHtml:
        "Los suplementos multivitamínicos y minerales, como <strong>Dayamineral</strong>, no han demostrado ser seguros",
      options: [
        { label: "MITO" },
        { label: "REALIDAD" },
      ],
      correct: "MITO",
      message:
        "Al ser un producto que influye en la salud humana, los suplementos multivitamínicos y minerales deben contar con el aval de la autoridad sanitaria técnica y científica del país donde se comercializa, lo que garantiza su calidad y seguridad. Por ello, es importante elegir productos de marcas de confianza, reconocidas por sus altos estándares de calidad, como es el caso de Dayamineral, que cuenta con el respaldo Abbott. Además, los casos reales de efectos negativos para la salud derivados de una ingesta excesiva de suplementos son poco frecuentes.",
      referencesHtml:
        "<strong>Referencias:</strong> <strong>1.</strong> Mister S. Five Myths About Dietary Supplements-And the Truth You Should Know. Integr Med (Encinitas). 2025 Dec;24(6):14-15. <strong>2.</strong> Monografía Dayamineral Jarabe. Junio 2019. <strong>3.</strong> Monografía Dayamineral Tabletas Recubiertas. Marzo 2019.",
      textColor: "#ffffff",
      logoVariant: "light",
    },
    {
      questionHtml:
        "Los suplementos multivitamínicos y minerales son todo lo que necesitan las personas para mantenerse saludables",
      options: [
        { label: "MITO" },
        { label: "REALIDAD" },
      ],
      correct: "MITO",
      message:
        "El consumo de suplementos multivitamínicos y minerales forma parte de un conjunto de hábitos saludables, que incluye una alimentación balanceada, ejercicio regular, dormir lo suficiente, evitar fumar y acudir periódicamente al médico. Los suplementos, por sí solos, no corrigen estilos de vida poco saludables. Su papel es complementar, no sustituir, y su beneficio es mayor cuando se integran dentro de un estilo de vida que favorece el bienestar general.",
      referencesHtml:
        "<strong>Referencia:</strong> Mister S. Five Myths About Dietary Supplements-And the Truth You Should Know. Integr Med (Encinitas). 2025 Dec;24(6):14-15.",
      textColor: "#111827",
      logoVariant: "dark",
    },
    {
      questionHtml:
        "La suplementación con <strong>Dayamineral</strong> también está indicada en situaciones que requieren mayores aportes de vitaminas y minerales",
      options: [
        { label: "MITO" },
        { label: "REALIDAD" },
      ],
      correct: "REALIDAD",
      message:
        "Algunas situaciones, como la actividad física intensa, el estrés y los estados de convalecencia, entre otras, aumentan las necesidades del organismo de vitaminas y minerales para funcionar correctamente y mantener la salud.",
      referencesHtml:
        "<strong>Referencias:</strong> <strong>1.</strong> Monografía Dayamineral Jarabe. Junio 2019. <strong>2.</strong> Monografía Dayamineral Tabletas Recubiertas. Marzo 2019.",
      textColor: "#111827",
      logoVariant: "dark",
    },
  ];

  const logoVariants = {
    light: {
      abbott: `${URL_BASE}/logos/abbott_white.webp`,
      dayamineral: `${URL_BASE}/logos/logo_dayamineral_white.webp`,
    },
    dark: {
      abbott: `${URL_BASE}/logos/abbott_black.webp`,
      dayamineral: `${URL_BASE}/logos/logo_dayamineral_color.webp`,
    },
  };

  const wrapper = document.getElementById("quiz-wrapper");
  const abbottLogo = document.getElementById("quiz-abbott-logo");
  const dayamineralLogo = document.getElementById("quiz-dayamineral-logo");
  const headerCode = document.getElementById("quiz-header-code");
  const quizCard = document.getElementById("quiz-card");
  const finishCard = document.getElementById("quiz-finish");
  const progress = document.getElementById("quiz-progress");
  const progressBar = document.getElementById("quiz-progress-bar");
  const resetButton = document.getElementById("quiz-reset");
  const questionCopy = document.getElementById("quiz-question-copy");
  const counter = document.getElementById("quiz-counter");
  const questionText = document.getElementById("quiz-question");
  const answersContainer = document.getElementById("quiz-answers");
  const footer = document.getElementById("quiz-footer");
  const footerReferences = document.getElementById("quiz-footer-references");
  const modal = document.getElementById("quiz-modal");
  const modalCard = document.getElementById("modal-card");
  const modalIcon = document.getElementById("modal-icon");
  const modalTitle = document.getElementById("modal-title");
  const modalMessage = document.getElementById("modal-message");
  const modalNext = document.getElementById("modal-next");
  const restartButton = document.getElementById("quiz-restart");
  let currentQuestion = 0;
  let correctAnswers = 0;
  let questionAnswered = false;
  let confettiTimer;

  const setBackground = (index) => {
    const backgroundNumber = String(index + 1).padStart(2, "0");
    wrapper.style.backgroundImage = `url(${URL_BASE}/backgrounds/bg_${backgroundNumber}.webp)`;
  };

  const setHeaderLogos = (logoVariant) => {
    const logos = logoVariants[logoVariant];
    abbottLogo.src = logos.abbott;
    dayamineralLogo.src = logos.dayamineral;
    headerCode.style.color = logoVariant === "light" ? "#ffffff" : "#111827";
  };

  const renderQuestion = () => {
    const question = questions[currentQuestion];
    questionAnswered = false;
    const progressValue = currentQuestion + 1;
    progress.setAttribute("aria-valuemax", String(questions.length));
    progress.setAttribute("aria-valuenow", String(progressValue));
    progressBar.style.width = `${(progressValue / questions.length) * 100}%`;
    counter.textContent = `${currentQuestion + 1}.`;
    questionText.innerHTML = question.questionHtml;
    questionCopy.style.color = question.textColor;
    questionCopy.style.setProperty("--question-copy-bg", question.logoVariant === "light" ? "#111827" : "#ffffff");
    counter.style.color = question.textColor;
    questionText.style.color = question.textColor;
    resetButton.style.color = question.textColor;
    footer.style.color = question.textColor;
    footerReferences.innerHTML = question.referencesHtml;
    footer.classList.remove("hidden");
    setHeaderLogos(question.logoVariant);
    modalNext.textContent = currentQuestion === questions.length - 1 ? "FINALIZAR" : "SIGUIENTE";
    answersContainer.replaceChildren(
      ...question.options.map((option) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className =
          "quiz-answer flex items-center gap-4 rounded-full px-6 py-4 text-left text-4xl font-black uppercase leading-none text-white shadow-[0_12px_22px_rgba(65,20,76,0.26)] transition hover:-translate-y-0.5 hover:shadow-[0_16px_28px_rgba(117,84,0,0.28)] focus-visible:outline-4 focus-visible:outline-offset-2 focus-visible:outline-white md:gap-5 md:px-8 md:py-5 md:text-5xl bg-cover bg-center";
        button.style.setProperty("--answer-gradient", `url(${URL_BASE}/bg_btn_01.webp)`);
        button.dataset.answer = option.label;
        const icon = document.createElement("img");
        icon.src = option.label === "MITO" ? `${URL_BASE}/iconos/rayo.webp` : `${URL_BASE}/iconos/check.webp`;
        icon.alt = "";
        icon.className = "h-auto w-9 shrink-0 md:h-11 md:w-11";
        icon.setAttribute("aria-hidden", "true");
        const label = document.createElement("span");
        label.textContent = option.label;
        button.append(icon, label);
        button.addEventListener("click", () => {
          openModal(option.label);
        });
        return button;
      }),
    );
    setBackground(currentQuestion);
  };

  const launchSideConfetti = () => {
    const confetti = window.quizConfetti;

    if (!confetti) return;

    confetti({
      particleCount: 70,
      spread: 55,
      angle: 60,
      origin: { x: 0, y: 0.55 },
      colors: ["#c62579", "#f4bd18", "#ffffff"],
    });
    confetti({
      particleCount: 70,
      spread: 55,
      angle: 120,
      origin: { x: 1, y: 0.55 },
      colors: ["#c62579", "#f4bd18", "#ffffff"],
    });
  };

  const launchPerfectFinishConfetti = () => {
    const confetti = window.quizConfetti;

    if (!confetti) return;

    const end = Date.now() + 5000;
    clearInterval(confettiTimer);
    confettiTimer = setInterval(() => {
      confetti({
        particleCount: 55,
        spread: 360,
        startVelocity: 32,
        origin: { x: Math.random(), y: Math.random() * 0.55 },
        colors: ["#c62579", "#f4bd18", "#ffffff"],
      });

      if (Date.now() > end) {
        clearInterval(confettiTimer);
      }
    }, 250);
  };

  const resetQuiz = () => {
    clearInterval(confettiTimer);
    currentQuestion = 0;
    correctAnswers = 0;
    closeModal();
    finishCard.classList.add("hidden");
    quizCard.classList.remove("hidden");
    renderQuestion();
  };

  const openModal = (selectedAnswer) => {
    if (questionAnswered) return;

    questionAnswered = true;
    const question = questions[currentQuestion];
    const isCorrect = selectedAnswer === question.correct;

    if (isCorrect) {
      correctAnswers += 1;
      launchSideConfetti();
    }

    modalTitle.textContent = isCorrect
      ? "¡Correcto!"
      : question.correct === "MITO"
        ? "¡UPS, ESTO ES UN MITO!"
        : "¡UPS, ESTO ES UNA REALIDAD!";
    modalIcon.src = isCorrect
      ? `${URL_BASE}/iconos/check.webp`
      : `${URL_BASE}/iconos/rayo.webp`;
    modalMessage.textContent = question.message;
    modalCard.style.backgroundImage = `url(${URL_BASE}/${isCorrect ? "bg_btn_01.webp" : "bg_div.webp"})`;
    modalCard.style.backgroundSize = "cover";
    modalCard.style.backgroundPosition = "center";
    modalCard.style.backgroundRepeat = "no-repeat";
    modalCard.style.color = "#ffffff";
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    modalNext.focus();
  };

  const closeModal = () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  };

  const showFinish = () => {
    quizCard.classList.add("hidden");
    footer.classList.add("hidden");
    finishCard.classList.remove("hidden");
    setHeaderLogos(questions[questions.length - 1].logoVariant);
    setBackground(questions.length - 1);

    if (correctAnswers === questions.length) {
      launchPerfectFinishConfetti();
    }
  };

  modalNext.addEventListener("click", () => {
    closeModal();

    if (currentQuestion === questions.length - 1) {
      showFinish();
      return;
    }

    currentQuestion += 1;
    renderQuestion();
  });

  resetButton.addEventListener("click", resetQuiz);
  restartButton.addEventListener("click", resetQuiz);

  renderQuestion();
</script>
